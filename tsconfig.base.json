{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,

    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "skipLibCheck": true,

    "noEmit": true
  }
}
