{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShindenToAnilist",
  "version": "0.1.0",
  "identifier": "io.github.kacperkondracki.shindentoanilist",
  "build": {
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShindenToAnilist",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "category": "Utility",
    "copyright": "Copyright © 2026 Kacper Kondracki",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
