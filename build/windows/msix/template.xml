<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="shindentoanilist"
        Arguments=""
        InstallLocation="C:\Program Files\ShindenToAnilist\ShindenToAnilist">
    </Installer>
    <PackageInformation
        PackageName="ShindenToAnilist"
        PackageDisplayName="ShindenToAnilist"
        PublisherName="CN=ShindenToAnilist"
        PublisherDisplayName="ShindenToAnilist"
        Version="0.1.0.0"
        PackageDescription="A ShindenToAnilist application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.shindentoanilist.app"
                Description="A ShindenToAnilist application"
                DisplayName="ShindenToAnilist"
                ExecutableName="shindentoanilist"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>ShindenToAnilist</DisplayName>
            <PublisherDisplayName>ShindenToAnilist</PublisherDisplayName>
            <Description>A ShindenToAnilist application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="shindentoanilist.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
